{
  "name": "backend",
  "version": "1.0.0",
  "main": "server.js",
  "type": "module",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --detectOpenHandles",
    "test:watch": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:coverage": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "dev": "nodemon --exec tsx server.ts",
    "kill": "npx kill-port 5003 || true",
    "predev": "npx kill-port 5003 || true",
    "start": "node dist/server.js",
    "db:indexes": "tsx config/createIndexes.ts",
    "db:optimize": "tsx config/createIndexes.ts",
    "audit:tenant": "bash scripts/check-tenant-coverage.sh",
    "reset:ratelimit": "tsx scripts/resetRateLimits.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "overrides": {
    "jose": "^4.15.9",
    "node-forge": "^1.3.3",
    "qs": "^6.14.1"
  },
  "dependencies": {
    "axios": "^1.13.2",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.9.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csv-parser": "^3.2.0",
    "dotenv": "^16.6.1",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.3.1",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.9.2",
    "jsonwebtoken": "^9.0.3",
    "lsof": "^0.0.4",
    "mongoose": "^8.21.0",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "node-cache": "^5.1.2",
    "nodemailer": "^7.0.11",
    "redis": "^5.10.0",
    "socket.io": "^4.8.3",
    "streamifier": "^0.1.1",
    "stripe": "^20.0.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/hpp": "^0.2.7",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.0.3",
    "@types/nodemailer": "^7.0.4",
    "@types/streamifier": "^0.1.2",
    "@types/supertest": "^6.0.3",
    "@types/winston": "^2.4.4",
    "artillery": "^2.0.27",
    "cross-env": "^10.1.0",
    "jest": "^30.2.0",
    "k6": "^0.0.0",
    "mongodb-memory-server": "^10.4.1",
    "newman": "^6.2.1",
    "nock": "^14.0.10",
    "nodemon": "^3.1.11",
    "sinon": "^21.0.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
